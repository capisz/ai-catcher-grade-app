DATABASE_URL=postgresql://postgres:postgres@localhost:5433/catcher_intel

# Recommended: single source of truth for the Next.js proxy target.
API_BASE_URL=http://127.0.0.1:8000

# Optional server-only override if the Next.js server should hit a different internal backend URL.
# INTERNAL_API_URL=http://127.0.0.1:8000

# Optional legacy/public alias. The web app still reads this, but API_BASE_URL is preferred.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
